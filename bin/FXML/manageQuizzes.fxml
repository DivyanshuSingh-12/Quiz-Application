<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1366.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.manageQuizzes">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" style="-fx-background-color: #F4F4F4;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0" style="-fx-background-color: #F4F4F4;">
               <children>
                  <TextField fx:id="searchInput" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" onAction="#searchInputfun" prefHeight="75.0" prefWidth="1137.0" promptText="Search quizzes by name...">
                     <padding>
                        <Insets bottom="5.0" left="10.0" right="5.0" top="5.0" />
                     </padding>
                     <font>
                        <Font size="28.0" />
                     </font>
                  </TextField>
                  <Button fx:id="searchBtn" mnemonicParsing="false" onMouseClicked="#searchBtnClicked" prefHeight="43.0" prefWidth="119.0" style="-fx-background-color: #005461;" text="Search" textFill="WHITE">
                     <font>
                        <Font name="Arial Bold" size="23.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <ListView fx:id="listresult" prefHeight="579.0" prefWidth="1306.0" />
            <HBox alignment="CENTER" prefHeight="88.0" prefWidth="1306.0" spacing="50.0">
               <children>
                  <Button fx:id="updateBtn" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onMouseClicked="#updatebtnClicked" prefHeight="44.0" prefWidth="143.0" style="-fx-background-color: #005461;" text="UPDATE" textFill="#f4f4f4">
                     <font>
                        <Font name="Arial Bold" size="23.0" />
                     </font>
                  </Button>
                  <Button fx:id="deleteBtn" layoutX="591.0" layoutY="28.0" mnemonicParsing="false" onMouseClicked="#deleteBtnClicked" prefHeight="44.0" prefWidth="143.0" style="-fx-background-color: #005461;" text="DELETE" textFill="#fafafa">
                     <font>
                        <Font name="Arial Bold" size="23.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
